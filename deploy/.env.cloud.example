# === NarraNexus Cloud Deployment Configuration ===

# Database (AWS RDS MySQL)
DATABASE_URL=mysql://user:password@your-rds-endpoint:3306/narranexus

# App Mode
APP_MODE=cloud

# Authentication (Supabase)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM Configuration (server-side defaults)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Claude Code (internal employees only)
CLAUDE_CODE_ENABLED=true
